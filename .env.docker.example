APP_NAME=GPValiseAPI
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=gpvalise
DB_USERNAME=gpvalise_user
DB_PASSWORD=secret

HOST_UID=1000
HOST_GID=1000

BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

FAKE_PAYMENT_MODE=success
PAYMENT_WEBHOOK_SECRET=change_me
PAYMENT_WEBHOOK_ALERT_EMAIL=admin@example.com

SLACK_ALERTS_ENABLED=false
SLACK_WEBHOOK_URL=