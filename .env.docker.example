APP_NAME=GPValiseAPI
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=gpvalise
DB_USERNAME=gpvalise_user
DB_PASSWORD=secret

BROADCAST_DRIVER=log
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CLIENT=phpredis

FAKE_PAYMENT_MODE=success
PAYMENT_WEBHOOK_SECRET=super_secret_webhook_key
PAYMENT_WEBHOOK_ALERT_EMAIL=admin@gp-valise.com

SLACK_ALERTS_ENABLED=true
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/XXX/XXX